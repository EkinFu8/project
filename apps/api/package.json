{
  "name": "@myapp/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./routers": {
      "types": "./src/routers/index.ts"
    }
  },
  "scripts": {
    "postinstall": "node -e \"if (process.env.CI) process.exit(0); require('child_process').execSync('PRISMA_ALLOW_PLACEHOLDER_DATABASE_URL=1 prisma generate', { stdio: 'inherit' })\"",
    "dev": "tsx watch src/server.ts",
    "build": "PRISMA_ALLOW_PLACEHOLDER_DATABASE_URL=1 prisma generate && node build.mjs",
    "start": "node dist/server.mjs",
    "typecheck": "PRISMA_ALLOW_PLACEHOLDER_DATABASE_URL=1 prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "PRISMA_ALLOW_PLACEHOLDER_DATABASE_URL=1 prisma generate",
    "db:push": "node --import ./load-env-pre.js ./node_modules/prisma/build/index.js db push",
    "db:push:demo": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres} node --import ./load-env-pre.js ./node_modules/prisma/build/index.js db push --accept-data-loss",
    "db:push:remote": "node --import ./run-prisma-remote.js ./node_modules/prisma/build/index.js db push",
    "db:push:remote:debug": "DEBUG=\"prisma:*\" node --import ./run-prisma-remote.js ./node_modules/prisma/build/index.js db push",
    "db:migrate": "node --import ./load-env-pre.js ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed-rich-demo.ts",
    "db:seed:remote": "node --import ./run-prisma-remote.js --import ./load-env-pre.js ./node_modules/prisma/build/index.js db seed",
    "db:studio": "node --import ./load-env-pre.js ./node_modules/prisma/build/index.js studio",
    "ocr:backfill": "tsx src/scripts/backfill-ocr.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@myapp/types": "workspace:*",
    "@myapp/utils": "workspace:*",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@trpc/server": "^11.0.0",
    "dotenv": "^16.6.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0"
  }
}
