generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  employeeID    String  @id @db.Char(10)
  employee_name String? @db.VarChar(50)
  job_desc      String? @db.VarChar(200)

  content_items ContentManagement[] @relation("content_owner_fk")

  @@map("employee")
}

model ContentManagement {
  fileID          String    @id @db.Char(64)
  filename        String?   @db.VarChar(100)
  url             String?   @db.VarChar(500)
  content_owner   String?   @db.VarChar(50)
  job_position    String?   @db.VarChar(20)
  last_modified   DateTime? @db.Date
  expiration_date DateTime? @db.Date
  content_type    String?   @db.VarChar(20)
  document_status String?   @db.VarChar(20)

  employee Employee? @relation("content_owner_fk", fields: [content_owner], references: [employeeID])

  @@map("content_management")
}
