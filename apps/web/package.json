{
  "name": "@myapp/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @myapp/api exec prisma generate && tsc -b && vite build",
    "start": "serve -s dist -l ${PORT:-3000}",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @myapp/api exec prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@myapp/api": "workspace:*",
    "@myapp/types": "workspace:*",
    "@myapp/ui": "workspace:*",
    "@myapp/utils": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.75.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "lucide-react": "^0.500.0",
    "react-router": "^7.0.0",
    "serve": "^14.2.0"
  },
  "devDependencies": {
    "@trpc/server": "^11.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.0",
    "vite": "^8.0.0"
  }
}
