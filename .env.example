# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma — direct Postgres connection to the Supabase local database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Frontend environment variables (VITE_ prefix required for Vite exposure)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
# Local: http://localhost:3000 | Production: https://your-api.up.railway.app
VITE_API_URL=http://localhost:3000

# API CORS — comma-separated allowed origins (defaults to localhost:5173,5174)
CORS_ORIGINS=

# Turborepo Remote Cache (optional)
TURBO_TOKEN=
TURBO_TEAM=
