# Monorepo root only (next to apps/) — loaded by @myapp/api, Prisma (prisma.config.ts), and Vite apps via .env then .env.local
#
# Production schema: apply `supabase/migrations/*.sql` to the cloud project (Supabase CLI `supabase link` +
# `supabase db push`, CI, or Dashboard SQL). Do not use `prisma db push` against Supabase — it will fight
# `auth.*` (GoTrue) and can propose destructive changes.
#
# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / API — Postgres (local: same URL twice is fine)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Remote-only Prisma `db push`: copy .env.database.remote.example → .env.database.remote with production DATABASE_URL,
# then from apps/api run `pnpm db:push:remote` (does not use local .env.local for the DB URL).

# Frontend environment variables (VITE_ prefix required for Vite exposure)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
#
# Demo Auth: `supabase db reset` / `supabase/seed.sql` and `pnpm --filter @myapp/api db:seed`
# (see `apps/api/prisma/ensure-demo-users.ts`) — user@hanover.test + admin@hanover.test, password HanoverTest123!
# Local: http://localhost:3000 | Production: https://your-api.up.railway.app
VITE_API_URL=http://127.0.0.1:3000

# API CORS — comma-separated allowed origins (defaults to localhost:5173,5174)
CORS_ORIGINS=

# Turborepo Remote Cache (optional)
TURBO_TOKEN=
TURBO_TEAM=
